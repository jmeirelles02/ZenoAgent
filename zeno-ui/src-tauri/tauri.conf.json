{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zeno-ui",
  "version": "0.1.0",
  "identifier": "com.dtdev.zeno",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
  {
    "label": "main",
    "title": "Zeno",
    "width": 800,
    "height": 720,
    "resizable": false,
    "fullscreen": false,
    "decorations": false,
    "transparent": true
  }
],  
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
